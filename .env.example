# ============================================================
# Copy this file to .env and fill in real values.
# Never commit the real .env file.
# ============================================================

# ---- App ----
APP_NAME=Enterprise RAG Assistant
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ---- LLM Provider ----
# One of: groq | openai | gemini | anthropic
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Embeddings ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ---- Reranker ----
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_DEVICE=cpu
RERANKER_TOP_K=5

# ---- Vector Store (Chroma) ----
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=enterprise_docs

# ---- Relational DB ----
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ---- Chunking ----
CHUNK_STRATEGY=recursive      # recursive | fixed | overlap
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ---- Retrieval ----
RETRIEVAL_TOP_K=10
SIMILARITY_THRESHOLD=0.3
HYBRID_SEARCH_ENABLED=true
BM25_WEIGHT=0.4
DENSE_WEIGHT=0.6

# ---- LangSmith ----
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=enterprise-rag

# ---- Security ----
API_KEY_HEADER_NAME=X-API-Key
BACKEND_API_KEY=change-me-to-a-random-secret
RATE_LIMIT_PER_MINUTE=30
MAX_UPLOAD_SIZE_MB=20
ALLOWED_FILE_EXTENSIONS=.pdf,.docx,.txt,.md,.csv,.json

# ---- MCP ----
MCP_FILESYSTEM_ROOT=./data/mcp_files
MCP_GITHUB_TOKEN=
MCP_NOTION_TOKEN=

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000
